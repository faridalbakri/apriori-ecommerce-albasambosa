APP_NAME=AlbaSambosa
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Trusted proxy IPs (wildcard '*' hanya untuk dev)
# production: isi dengan IP Nginx/Cloudflare spesifik, e.g. '173.245.48.0/20,103.21.244.0/22'
TRUSTED_PROXIES=*

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

# Social Media
APP_SOCIAL_INSTAGRAM=
APP_SOCIAL_TIKTOK=
APP_SOCIAL_FACEBOOK=

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=albasambosa
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=file
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="admin@albasambosa.com"
MAIL_FROM_NAME="${APP_NAME}"

# PHP_CLI_SERVER_WORKERS=4

# Midtrans Payment Gateway
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_MERCHANT_ID=
MIDTRANS_IS_PRODUCTION=false
MIDTRANS_IS_SANITIZED=true
MIDTRANS_IS_3DS=true

# Biteship Delivery
BITESHIP_API_KEY=
BITESHIP_IS_PRODUCTION=false
BITESHIP_WEBHOOK_IPS=
BITESHIP_ORIGIN_POSTAL_CODE=11630
BITESHIP_ORIGIN_ADDRESS="Jl. G No.120, RT.8/RW.6, Srengseng, Kec. Kembangan, Kota Jakarta Barat, Daerah Khusus Ibukota Jakarta 11630"
BITESHIP_ORIGIN_CONTACT_NAME=AlbaSambosa
BITESHIP_ORIGIN_CONTACT_PHONE=085780159620
BITESHIP_ORIGIN_CONTACT_EMAIL=admin@albasambosa.com

# WhatsApp Notification (Twilio / WATI)
WHATSAPP_PROVIDER=twilio
TWILIO_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
TWILIO_STORE_ADDRESS="Jl. G No.120, RT.8/RW.6, Srengseng, Kec. Kembangan, Jakarta Barat 11630"
TWILIO_STORE_HOURS="09.00 - 20.00 WIB"

# Sentry Error Monitoring
SENTRY_LARAVEL_DSN=
SENTRY_ENVIRONMENT=local

VITE_APP_NAME="${APP_NAME}"

# Cloudflare R2 Backup (S3-compatible)
# 10 GB gratis, no egress fee. Endpoint dari dashboard R2.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=auto
AWS_BUCKET=
AWS_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
AWS_USE_PATH_STYLE_ENDPOINT=true
